{# Common variables for baseline states #}

{# Robust container detection.
   We prefer lightweight file-based checks first (no external commands),
   then fall back to grains, then systemd-detect-virt as last resort.
#}
{%- set has_dockerenv = salt['file.file_exists']('/.dockerenv') %}
{%- set has_containerenv = salt['file.file_exists']('/run/.containerenv') %}

{%- set virtual = grains.get('virtual', '') | lower %}
{%- set virtual_subtype = grains.get('virtual_subtype', '') | lower %}

{%- set grains_says_container = virtual in ('container', 'docker', 'lxc', 'systemd-nspawn', 'podman') or
                               'container' in virtual or
                               virtual_subtype in ('docker', 'lxc', 'container', 'podman') %}

{# Last resort: call systemd-detect-virt (with ignore_retcode so it never breaks rendering) #}
{%- set virt_output = salt['cmd.run'](
      'systemd-detect-virt --container 2>/dev/null || echo "none"',
      python_shell=True,
      ignore_retcode=True
    ) | trim | lower %}

{%- set systemd_says_container = virt_output not in ('none', '', 'none\n') %}

{%- set running_in_container = has_dockerenv or has_containerenv or grains_says_container or systemd_says_container %}

# =============================================================================
# SUSE Baseline - Audit Rules (Forensic Focus)
# Managed by Salt. Based on SUSE Security and Hardening Guide + common
# high-value forensic watches.
# =============================================================================

# Increase buffer size
-b 8192

# Failure handling
-f 1

# =============================================================================
# Watch critical authentication & identity files
# =============================================================================
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity

# =============================================================================
# Sudo / Privilege escalation
# =============================================================================
-w /etc/sudoers -p wa -k privilege_escalation
-w /etc/sudoers.d/ -p wa -k privilege_escalation

# =============================================================================
# SSH (keys and config) - note: full ssh module skipped due to FreeIPA
# =============================================================================
-w /etc/ssh/sshd_config -p wa -k sshd
-w /etc/ssh/sshd_config.d/ -p wa -k sshd
-w /root/.ssh/ -p wa -k ssh_keys

# =============================================================================
# PAM configuration
# =============================================================================
-w /etc/pam.d/ -p wa -k pam_config

# =============================================================================
# Cron / at
# =============================================================================
-w /etc/crontab -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
-w /var/spool/cron/ -p wa -k cron

# =============================================================================
# Kernel modules
# =============================================================================
-w /etc/modprobe.d/ -p wa -k modules
-a always,exit -F arch=b64 -S init_module -S delete_module -k modules

# =============================================================================
# Systemd & service changes
# =============================================================================
-w /etc/systemd/system/ -p wa -k systemd
-w /etc/systemd/user/ -p wa -k systemd

# =============================================================================
# Log files (protect audit logs themselves)
# =============================================================================
-w /var/log/audit/ -p wa -k audit_log
-w /var/log/ -p wa -k log_files

# =============================================================================
# File system mounts
# =============================================================================
-a always,exit -F arch=b64 -S mount -F auid>=1000 -F auid!=4294967295 -k mounts

# =============================================================================
# Execution of binaries in sensitive locations (optional, can be noisy)
# =============================================================================
# -w /usr/bin/ -p x -k exec_bin
# -w /usr/sbin/ -p x -k exec_sbin

# =============================================================================
# Unsuccessful file access attempts
# =============================================================================
-a always,exit -F arch=b64 -S open,openat,open_by_handle_at -F exit=-EACCES -k access
-a always,exit -F arch=b64 -S open,openat,open_by_handle_at -F exit=-EPERM -k access

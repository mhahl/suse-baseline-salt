# =============================================================================
# SUSE Baseline - Systemd Coredump Hardening
# Prevents sensitive data leakage from crashes while allowing limited forensics.
# =============================================================================

[ Coredump ]

# Disable or limit core dumps
Storage=external
Compress=yes

# Limit total disk usage (important on rolling Tumbleweed)
MaxUse={{ pillar.get('baseline:coredump:max_use', '2G') }}
KeepFree={{ pillar.get('baseline:coredump:keep_free', '4G') }}
MaxFileSize={{ pillar.get('baseline:coredump:max_file_size', '1G') }}

# Only keep the most recent N dumps
MaxFiles={{ pillar.get('baseline:coredump:max_files', 3) }}

# Drop privileges when writing
ProcessSizeMax={{ pillar.get('baseline:coredump:process_size_max', '2G') }}

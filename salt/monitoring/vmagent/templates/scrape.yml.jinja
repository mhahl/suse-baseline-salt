global:
  external_labels:
    hostname: "{{ grains['host'] }}"
    fqdn:     "{{ grains['fqdn'] }}"
    env:      "{{ vmagent.get('environment', 'production') }}"

scrape_configs:
  - job_name: 'falco'
    static_configs:
      - targets:
          - '127.0.0.1:8765'
    metrics_path: /metrics

  - job_name: node_exporter
    static_configs:
      - targets: ['127.0.0.1:9100']
        labels:
          instance: "{{ grains['host'] }}"
          host:     "{{ grains['fqdn'] }}"
    scrape_interval: 15s

  - job_name: vmagent
    static_configs:
      - targets: ['127.0.0.1:8429']
        labels:
          instance: "{{ grains['host'] }}"
          host:     "{{ grains['fqdn'] }}"
    scrape_interval: 15s

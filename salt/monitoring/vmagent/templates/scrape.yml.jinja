global:
  external_labels:
    hostname: "{{ grains['host'] }}"
    fqdn:     "{{ grains['fqdn'] }}"
    env:      "{{ vmagent.get('environment', 'production') }}"

  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'falco'
    static_configs:
      - targets:
          - '127.0.0.1:8765'
    metrics_path: /metrics

  - job_name: 'blackbox_exporter'
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
          - 8.8.8.8
          - 1.1.1.1
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:9115

  - job_name: node_exporter
    static_configs:
      - targets: ['127.0.0.1:9100']
        labels:
          instance: "{{ grains['host'] }}"
          host:     "{{ grains['fqdn'] }}"
    scrape_interval: 15s

  - job_name: vmagent
    static_configs:
      - targets: ['127.0.0.1:8429']
        labels:
          instance: "{{ grains['host'] }}"
          host:     "{{ grains['fqdn'] }}"
    scrape_interval: 15s

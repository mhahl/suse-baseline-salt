global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Scrape the local node_exporter (deployed as part of this baseline)
  - job_name: node
    static_configs:
      - targets: ['localhost:9100']

  # Scrape vmagent's own metrics (httpListenAddr in the unit)
  - job_name: vmagent
    static_configs:
      - targets: ['localhost:8429']

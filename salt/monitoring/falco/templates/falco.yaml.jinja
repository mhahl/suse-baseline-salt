rules_file:
  - /etc/falco/falco_rules.yaml
  - /etc/falco/falco_rules.local.yaml
  - /etc/falco/rules.d

json_output: true
json_include_output_property: true

http_output:
  enabled: true
  url: {{ falco.get('http_output_url', 'https://falco.sigaint.au') }}

logging:
  enabled: true
  level: info
  destination: /var/log/falco/falco.log

stdout_output:
  enabled: false

syslog_output:
  enabled: false

file_output:
  enabled: false

program_output:
  enabled: false
